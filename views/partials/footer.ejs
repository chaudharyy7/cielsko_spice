            <li><a href="/privacy-policy">Privacy Policy</a></li>
            <li><a href="/terms-conditions">Terms & Conditions</a></li>
            <li><a href="/disclaimer">Disclaimer</a></li>
            <li><a href="/cookie-policy">Cookie Policy</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h4 class="footer__title">Contact</h4>
          <ul class="footer__contact">
            <li><i class="fa-solid fa-location-dot"></i><span><%= settings?.contact_address || 'P50, P Block, P Extension, Mohan Garden, New Delhi – 110059, India' %></span></li>
            <li><i class="fa-solid fa-envelope"></i><a href="mailto:<%= settings?.contact_email || 'info@cielsko.com' %>"><%= settings?.contact_email || 'info@cielsko.com' %></a></li>
            <li><i class="fa-solid fa-phone"></i><a href="tel:<%= settings?.contact_phone1 || '+917053086259' %>"><%= settings?.contact_phone1 || '+91-7053086259' %></a></li>
            <% if (settings?.contact_phone2) { %><li><i class="fa-solid fa-phone"></i><a href="tel:<%= settings.contact_phone2 %>"><%= settings.contact_phone2 %></a></li><% } %>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer__bottom">
      <div class="container footer__bottom-inner">
        <p>&copy; 2025 Cielsko. All Rights Reserved.</p>
