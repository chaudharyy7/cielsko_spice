<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="icon" href="/images/favicon.svg"/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: #1A0F08; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-bg { position: fixed; inset: 0; background: radial-gradient(circle at 30% 50%, rgba(232,96,28,0.12) 0%, transparent 60%), radial-gradient(circle at 80% 20%, rgba(201,150,26,0.08) 0%, transparent 50%); pointer-events: none; }
    .login-card { background: #2C1810; border: 1px solid rgba(232,96,28,0.2); border-radius: 20px; padding: 48px 40px; width: 100%; max-width: 420px; position: relative; z-index: 1; box-shadow: 0 40px 80px rgba(0,0,0,0.5); }
    .login-logo { text-align: center; margin-bottom: 32px; }
    .login-logo .icon { font-size: 3rem; display: block; margin-bottom: 8px; }
    .login-logo h1 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: #FDF6E3; letter-spacing: 0.05em; }
    .login-logo p { font-size: 0.78rem; color: rgba(253,246,227,0.4); letter-spacing: 0.15em; text-transform: uppercase; margin-top: 4px; }
    .login-title { font-size: 1.05rem; color: rgba(253,246,227,0.7); text-align: center; margin-bottom: 28px; font-weight: 400; }
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; font-size: 0.8rem; font-weight: 600; color: rgba(253,246,227,0.6); margin-bottom: 7px; letter-spacing: 0.06em; text-transform: uppercase; }
    .form-group .input-wrap { position: relative; }
    .form-group .input-wrap i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: rgba(253,246,227,0.3); font-size: 0.9rem; }
    .form-group input { width: 100%; padding: 12px 14px 12px 40px; background: rgba(253,246,227,0.05); border: 1.5px solid rgba(253,246,227,0.1); border-radius: 10px; color: #FDF6E3; font-size: 0.95rem; font-family: inherit; transition: all 0.25s; }
    .form-group input:focus { outline: none; border-color: #E8601C; background: rgba(232,96,28,0.06); }
    .form-group input::placeholder { color: rgba(253,246,227,0.25); }
    .btn-login { width: 100%; padding: 14px; background: linear-gradient(135deg, #E8601C, #C44E14); color: #fff; border: none; border-radius: 10px; font-size: 1rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.25s; margin-top: 8px; }
    .btn-login:hover { background: linear-gradient(135deg, #C44E14, #9B3A0E); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(232,96,28,0.4); }
    .error-msg { background: rgba(232,96,28,0.12); border: 1px solid rgba(232,96,28,0.3); color: #F09070; border-radius: 8px; padding: 12px 16px; font-size: 0.88rem; margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
    .login-back { text-align: center; margin-top: 20px; font-size: 0.82rem; color: rgba(253,246,227,0.3); }
    .login-back a { color: #E8601C; text-decoration: none; }
    .login-back a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="login-bg"></div>
  <div class="login-card">
    <div class="login-logo">
      <span class="icon">🌶️</span>
      <h1>Cielsko</h1>
      <p>Admin Panel</p>
    </div>
    <p class="login-title">Sign in to manage your website</p>

    <% if (error) { %>
    <div class="error-msg"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div class="form-group">
        <label>Username</label>
        <div class="input-wrap">
          <i class="fa-solid fa-user"></i>
          <input type="text" name="username" placeholder="admin" autocomplete="username" required />
        </div>
      </div>
      <div class="form-group">
        <label>Password</label>
        <div class="input-wrap">
          <i class="fa-solid fa-lock"></i>
          <input type="password" name="password" placeholder="••••••••" autocomplete="current-password" required />
        </div>
      </div>
      <button type="submit" class="btn-login">Sign In <i class="fa-solid fa-arrow-right"></i></button>
    </form>
    <div class="login-back"><a href="/">← Back to website</a></div>
  </div>
</body>
</html>
