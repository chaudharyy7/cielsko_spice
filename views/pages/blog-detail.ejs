<%- include('../partials/header') %>

<section class="page-hero page-hero--sm">
  <div class="container">
    <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <a href="/blog">Blog</a> <span>/</span> <span><%= blog.title.substring(0,40) %>...</span></nav>
  </div>
  <div class="page-hero__pattern"></div>
</section>

<section class="section blog-detail-page">
  <div class="container blog-page__layout">

    <article class="blog-detail">
      <div class="blog-detail__header">
        <div class="blog-detail__meta">
          <span class="blog-list-card__cat"><%= blog.category %></span>
          <span><i class="fa-regular fa-calendar"></i> <%= new Date(blog.publishedAt).toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'}) %></span>
          <span><i class="fa-regular fa-user"></i> <%= blog.author %></span>
        </div>
        <h1 class="blog-detail__title"><%= blog.title %></h1>
        <div class="blog-detail__tags">
          <% if (blog.tags) { blog.tags.forEach(tag => { %>
          <a href="/blog?tag=<%= tag %>" class="tag">#<%= tag %></a>
          <% }) } %>
        </div>
      </div>

      <% if (blog.image) { %>
      <div class="blog-detail__featured-img">
        <img src="<%= blog.image %>" alt="<%= blog.title %>" onerror="this.src='/images/placeholder-blog.svg'" />
      </div>
      <% } %>

      <div class="blog-detail__content">
        <%- blog.content %>
      </div>

      <div class="blog-detail__share">
        <span>Share:</span>
        <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(blog.title) %>" target="_blank" rel="noopener" aria-label="Share on X"><i class="fa-brands fa-x-twitter"></i></a>
        <a href="https://www.linkedin.com/sharing/share-offsite/?url=" target="_blank" rel="noopener" aria-label="Share on LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
        <a href="https://wa.me/?text=<%= encodeURIComponent(blog.title) %>" target="_blank" rel="noopener" aria-label="Share on WhatsApp"><i class="fa-brands fa-whatsapp"></i></a>
      </div>
    </article>

    <!-- Sidebar -->
    <aside class="blog-sidebar">
      <div class="sidebar-widget">
        <h3 class="sidebar-widget__title">Recent Posts</h3>
        <ul class="sidebar-recent">
          <% if (recentBlogs && recentBlogs.length > 0) { %>
            <% recentBlogs.forEach(post => { %>
            <li class="sidebar-recent__item">
              <a href="/blog/<%= post.slug %>"><%= post.title %></a>
              <span><%= new Date(post.publishedAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></span>
            </li>
            <% }) %>
          <% } %>
        </ul>
      </div>
      <% if (allTags && allTags.length > 0) { %>
      <div class="sidebar-widget">
        <h3 class="sidebar-widget__title">Tags</h3>
        <div class="sidebar-tags">
          <% allTags.forEach(tag => { %>
          <a href="/blog?tag=<%= tag %>" class="tag">#<%= tag %></a>
          <% }) %>
        </div>
      </div>
      <% } %>
      <div class="sidebar-widget sidebar-cta">
        <h3>Need Premium Spices?</h3>
        <p>Get in touch for bulk orders and custom requirements.</p>
        <a href="/contact" class="btn btn--primary btn--block">Get a Free Quote</a>
      </div>
    </aside>

  </div>
</section>

<%- include('../partials/footer') %>
