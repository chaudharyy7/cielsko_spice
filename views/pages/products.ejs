<%- include('../partials/header') %>

<section class="page-hero">
  <div class="container">
    <nav class="breadcrumb"><a href="/">Home</a> <span>/</span> <span>Products</span></nav>
    <h1 class="page-hero__title">Our <em>Products</em></h1>
    <p class="page-hero__subtitle">Premium Indian Spices — Whole, Ground & Blended</p>
  </div>
  <div class="page-hero__pattern"></div>
</section>

<section class="section products-page">
  <div class="container">
    <!-- Filters -->
    <div class="products-filter">
      <a href="/products" class="filter-btn <%= selectedCategory === 'all' ? 'active' : '' %>">All Spices</a>
      <a href="/products?category=whole" class="filter-btn <%= selectedCategory === 'whole' ? 'active' : '' %>">Whole Spices</a>
      <a href="/products?category=ground" class="filter-btn <%= selectedCategory === 'ground' ? 'active' : '' %>">Ground Spices</a>
      <a href="/products?category=blended" class="filter-btn <%= selectedCategory === 'blended' ? 'active' : '' %>">Blended Spices</a>
      <a href="/products?category=leaves" class="filter-btn <%= selectedCategory === 'leaves' ? 'active' : '' %>">Leaves & Herbs</a>
      <a href="/products?category=other" class="filter-btn <%= selectedCategory === 'other' ? 'active' : '' %>">Other</a>
    </div>

    <div class="products-grid products-grid--page">
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>
        <div class="product-card">
          <div class="product-card__img">
            <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" onerror="this.src='/images/placeholder-spice.svg'" />
            <div class="product-card__overlay">
              <a href="/products/<%= product.slug %>" class="btn btn--light btn--sm">View Details</a>
            </div>
          </div>
          <div class="product-card__body">
            <span class="product-card__cat"><%= product.category %></span>
            <h3 class="product-card__name"><%= product.name %></h3>
            <p class="product-card__desc"><%= product.shortDescription.substring(0, 110) %>...</p>
            <a href="/products/<%= product.slug %>" class="product-card__link">Read More <i class="fa-solid fa-arrow-right"></i></a>
          </div>
        </div>
        <% }) %>
      <% } else { %>
        <% const allProducts = [
          {name:'Red Chilli', slug:'red-chilli', emoji:'🌶️', desc:'Sourced for optimal heat and color, our red chillies are ideal for adding a fiery kick to your recipes.', cat:'whole'},
          {name:'Whole Turmeric', slug:'whole-turmeric', emoji:'🟡', desc:'Whole turmeric is the root of the turmeric plant — a golden spice with a warm, earthy flavor and high curcumin content.', cat:'whole'},
          {name:'Green Cardamom', slug:'green-cardamom', emoji:'🌿', desc:'Aromatic and sweet, our cardamom pods elevate the flavor of teas, desserts, and savory dishes.', cat:'whole'},
          {name:'Dry Ginger Whole', slug:'dry-ginger', emoji:'🍵', desc:'Nutrient-rich Dry Ginger Whole ideal for dals, soups, and daily cooking.', cat:'whole'},
          {name:'Clove', slug:'clove', emoji:'🔵', desc:'Known for its intense aroma and rich flavor, our cloves add a burst of taste to every dish.', cat:'whole'},
          {name:'Cinnamon', slug:'cinnamon', emoji:'🍂', desc:'Sweet and aromatic, our premium cinnamon enhances both sweet and savory dishes.', cat:'whole'},
          {name:'Senna Leaves', slug:'senna-leaves', emoji:'🌱', desc:'Pure, sun-dried Senna Leaves traditionally used to promote healthy digestion and detoxification.', cat:'leaves'},
          {name:'Black Pepper', slug:'black-pepper', emoji:'⚫', desc:'Often called the "King of Spices," our black peppercorns are bold, pungent, and freshly packed.', cat:'whole'},
          {name:'Bay Leaves (Tej Patta)', slug:'bay-leaves', emoji:'🍃', desc:'Naturally dried Bay Leaves that add depth and fragrance to a variety of dishes.', cat:'leaves'},
          {name:'Nutmeg', slug:'nutmeg', emoji:'🟤', desc:'A warm, aromatic spice that adds rich flavor to sweets, curries, and beverages.', cat:'whole'},
          {name:'Kasuri Methi', slug:'kasuri-methi', emoji:'🌿', desc:'Flavorful dry fenugreek leaves perfect for curries, dals, and snacks.', cat:'leaves'},
          {name:'Star Anise', slug:'star-anise', emoji:'⭐', desc:'A fragrant spice with a sweet, licorice-like flavor, perfect for biryanis, teas, and curries.', cat:'whole'},
          {name:'Smoke-Dried Chilli', slug:'smoke-dried-chilli', emoji:'🌋', desc:'Bold and smoky dried chillies that add deep flavor and heat to curries and marinades.', cat:'whole'},
        ]; %>
        <% allProducts.forEach(p => { %>
        <div class="product-card">
          <div class="product-card__img product-card__img--emoji">
            <span class="product-emoji"><%= p.emoji %></span>
            <div class="product-card__overlay">
              <a href="/products/<%= p.slug %>" class="btn btn--light btn--sm">View Details</a>
            </div>
          </div>
          <div class="product-card__body">
            <span class="product-card__cat"><%= p.cat %></span>
            <h3 class="product-card__name"><%= p.name %></h3>
            <p class="product-card__desc"><%= p.desc %></p>
            <a href="/products/<%= p.slug %>" class="product-card__link">Read More <i class="fa-solid fa-arrow-right"></i></a>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="cta-banner__pattern"></div>
  <div class="container cta-banner__inner">
    <div class="cta-banner__text">
      <h2>Can't Find What You Need?</h2>
      <p>We source a wide range of Indian spices. Contact us with your requirements and we'll find the perfect solution for you.</p>
    </div>
    <div class="cta-banner__actions">
      <a href="/contact" class="btn btn--gold btn--lg">Request a Custom Quote</a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
